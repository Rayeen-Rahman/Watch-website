# ═══════════════════════════════════════════════════
#  Watch Vault — Backend Environment Variables
#  Copy to .env and fill in your values
# ═══════════════════════════════════════════════════

# Server
PORT=5000
NODE_ENV=production

# MongoDB (replace with your Atlas connection string in production)
MONGO_URI=mongodb://127.0.0.1:27017/watch-store

# CORS — your deployed frontend URL (e.g. https://watchvault.vercel.app)
FRONTEND_URL=http://localhost:5173

# JWT (add when auth is implemented)
# JWT_SECRET=your_super_secret_key_here
# JWT_EXPIRE=30d
